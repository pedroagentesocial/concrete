---
import SectionHeader from "./SectionHeader.astro";
import { t, type Lang } from "../i18n";
import { services } from "../data/services";
const { lang } = Astro.props as { lang: Lang };
---
<section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16 sm:py-20">
  <SectionHeader title={t(lang, "home.services.title")} subtitle={t(lang, "home.services.subtitle")} align="center" />
  <div class="grid gap-6 lg:grid-cols-3 sm:auto-rows-[200px] lg:auto-rows-[240px]">
    {(() => {
      const svc = services[0];
      const bullets = svc.bulletsKey ? (t(lang, svc.bulletsKey) as any[]) : null;
      return (
        <article class="bg-surface rounded-2xl border border-muted p-6 lg:col-start-1 lg:row-start-1 h-full min-h-[200px] lg:min-h-[240px] overflow-hidden transition-all duration-200 ease-out hover:border-brand hover:-translate-y-0.5 active:translate-y-0 active:scale-[0.99]">
          <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-xl border border-muted text-text/80" set:html={svc.icon} />
          <h3 class="text-xl font-semibold text-text">{t(lang, svc.titleKey)}</h3>
          <p class="mt-2 text-sm leading-snug text-text/80">{t(lang, svc.descriptionKey)}</p>
          {bullets && Array.isArray(bullets) && bullets.length > 0 ? (
            <ul class="mt-3 space-y-2 text-xs leading-snug text-text/80">
              {bullets.map((b) => <li>{b}</li>)}
            </ul>
          ) : null}
        </article>
      );
    })()}

    <div class="relative rounded-2xl overflow-hidden border border-muted lg:col-start-2 lg:row-start-1 lg:row-span-2 h-full min-h-[400px] lg:min-h-[480px] order-first lg:order-none">
      <picture>
        <source srcset="/images/worker.jpg" type="image/jpeg" />
        <img
          src="/images/worker.jpg"
          alt={t(lang, "home.services.images.heroAlt")}
          loading="lazy"
          class="h-full w-full object-cover"
        />
      </picture>
      <div class="pointer-events-none absolute left-4 top-4 rounded-full border border-muted bg-white/80 px-3 py-1 text-xs font-semibold text-text">
        {t(lang, "home.services.imageLabel")}
      </div>
    </div>

    {(() => {
      const svc = services[1];
      const bullets = svc.bulletsKey ? (t(lang, svc.bulletsKey) as any[]) : null;
      return (
        <article class="bg-surface rounded-2xl border border-muted p-6 lg:col-start-3 lg:row-start-1 h-full min-h-[200px] lg:min-h-[240px] overflow-hidden transition-all duration-200 ease-out hover:border-brand hover:-translate-y-0.5 active:translate-y-0 active:scale-[0.99]">
          <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-xl border border-muted text-text/80" set:html={svc.icon} />
          <h3 class="text-xl font-semibold text-text">{t(lang, svc.titleKey)}</h3>
          <p class="mt-2 text-sm leading-snug text-text/80">{t(lang, svc.descriptionKey)}</p>
          {bullets && Array.isArray(bullets) && bullets.length > 0 ? (
            <ul class="mt-3 space-y-2 text-xs leading-snug text-text/80">
              {bullets.map((b) => <li>{b}</li>)}
            </ul>
          ) : null}
        </article>
      );
    })()}

    {(() => {
      const svc = services[2];
      const bullets = svc.bulletsKey ? (t(lang, svc.bulletsKey) as any[]) : null;
      return (
        <article class="bg-surface rounded-2xl border border-muted p-6 lg:col-start-1 lg:row-start-2 h-full min-h-[200px] lg:min-h-[240px] overflow-hidden transition-all duration-200 ease-out hover:border-brand hover:-translate-y-0.5 active:translate-y-0 active:scale-[0.99]">
          <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-xl border border-muted text-text/80" set:html={svc.icon} />
          <h3 class="text-xl font-semibold text-text">{t(lang, svc.titleKey)}</h3>
          <p class="mt-2 text-sm leading-snug text-text/80">{t(lang, svc.descriptionKey)}</p>
          {bullets && Array.isArray(bullets) && bullets.length > 0 ? (
            <ul class="mt-3 space-y-2 text-xs leading-snug text-text/80">
              {bullets.map((b) => <li>{b}</li>)}
            </ul>
          ) : null}
        </article>
      );
    })()}

    {(() => {
      const svc = services[3];
      const bullets = svc.bulletsKey ? (t(lang, svc.bulletsKey) as any[]) : null;
      return (
        <article class="bg-surface rounded-2xl border border-muted p-6 lg:col-start-3 lg:row-start-2 h-full min-h-[200px] lg:min-h-[240px] overflow-hidden transition-all duration-200 ease-out hover:border-brand hover:-translate-y-0.5 active:translate-y-0 active:scale-[0.99]">
          <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-xl border border-muted text-text/80" set:html={svc.icon} />
          <h3 class="text-xl font-semibold text-text">{t(lang, svc.titleKey)}</h3>
          <p class="mt-2 text-sm leading-snug text-text/80">{t(lang, svc.descriptionKey)}</p>
          {bullets && Array.isArray(bullets) && bullets.length > 0 ? (
            <ul class="mt-3 space-y-2 text-xs leading-snug text-text/80">
              {bullets.map((b) => <li>{b}</li>)}
            </ul>
          ) : null}
        </article>
      );
    })()}
  </div>
</section>
