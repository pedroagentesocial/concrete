---
import SectionHeader from "./SectionHeader.astro";
import ButtonLink from "./ButtonLink";
import { contactInfo } from "../data/contactInfo";
import { t, type Lang } from "../i18n";

const { lang } = Astro.props as { lang: Lang };
---

<section class="bg-white">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-16 sm:py-20">
    <SectionHeader title={t(lang, "pages.contact.methods.title")} subtitle={t(lang, "pages.contact.methods.subtitle")} align="center" />
    <div class="grid gap-6 lg:gap-8 md:grid-cols-2 lg:grid-cols-3">
      <article class="rounded-2xl border border-muted bg-surface p-6 transition-all duration-200 ease-out hover:border-brand hover:-translate-y-0.5 focus-within:outline focus-within:outline-2 focus-within:outline-brand focus-within:outline-offset-2">
        <div class="inline-flex h-11 w-11 items-center justify-center rounded-xl border border-muted bg-white text-brand">
          <svg viewBox="0 0 24 24" aria-hidden="true" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <rect x="7" y="2" width="10" height="20" rx="2" />
            <path d="M11 18h2" />
          </svg>
        </div>
        <h3 class="mt-4 text-lg font-semibold text-text">{t(lang, "pages.contact.methods.call.title")}</h3>
        <p class="mt-2 text-sm text-text/80">{t(lang, "pages.contact.methods.call.subtitle")}</p>
        <div class="mt-4 text-sm text-text/80">
          <span class="text-xs uppercase tracking-[0.2em] text-muted">{t(lang, "footer.labels.phone")}</span>
          <p class="mt-1 font-semibold text-text">{t(lang, "home.contact.phone")}</p>
        </div>
        <div class="mt-6">
          <ButtonLink href={contactInfo.phoneHref} variant="primary" className="h-11 px-5">
            {t(lang, "pages.contact.methods.call.cta") as any}
          </ButtonLink>
        </div>
      </article>

      <article class="rounded-2xl border border-muted bg-surface p-6 transition-all duration-200 ease-out hover:border-brand hover:-translate-y-0.5 focus-within:outline focus-within:outline-2 focus-within:outline-brand focus-within:outline-offset-2">
        <div class="inline-flex h-11 w-11 items-center justify-center rounded-xl border border-muted bg-white text-brand">
          <svg viewBox="0 0 24 24" aria-hidden="true" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="5" width="18" height="14" rx="2" />
            <path d="M3 7l9 6 9-6" />
          </svg>
        </div>
        <h3 class="mt-4 text-lg font-semibold text-text">{t(lang, "pages.contact.methods.email.title")}</h3>
        <p class="mt-2 text-sm text-text/80">{t(lang, "pages.contact.methods.email.subtitle")}</p>
        <div class="mt-4 text-sm text-text/80">
          <span class="text-xs uppercase tracking-[0.2em] text-muted">{t(lang, "footer.labels.email")}</span>
          <p class="mt-1 font-semibold text-text">{t(lang, "home.contact.email")}</p>
        </div>
        <div class="mt-6">
          <ButtonLink href={contactInfo.emailHref} variant="secondary" className="h-11 px-5">
            {t(lang, "pages.contact.methods.email.cta") as any}
          </ButtonLink>
        </div>
      </article>

      <article class="rounded-2xl border border-muted bg-surface p-6 transition-all duration-200 ease-out hover:border-brand hover:-translate-y-0.5 focus-within:outline focus-within:outline-2 focus-within:outline-brand focus-within:outline-offset-2">
        <div class="inline-flex h-11 w-11 items-center justify-center rounded-xl border border-muted bg-white text-brand">
          <svg viewBox="0 0 24 24" aria-hidden="true" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 21l-5-7a6 6 0 1 1 10 0l-5 7" />
            <circle cx="12" cy="10" r="2.5" />
          </svg>
        </div>
        <h3 class="mt-4 text-lg font-semibold text-text">{t(lang, "pages.contact.methods.directions.title")}</h3>
        <p class="mt-2 text-sm text-text/80">{t(lang, "pages.contact.methods.directions.subtitle")}</p>
        <div class="mt-4 text-sm text-text/80">
          <span class="text-xs uppercase tracking-[0.2em] text-muted">{t(lang, "footer.labels.address")}</span>
          <p class="mt-1 font-semibold text-text">{t(lang, "home.contact.address")}</p>
        </div>
        <div class="mt-6">
          <ButtonLink href={contactInfo.mapHref} target="_blank" rel="noopener noreferrer" variant="primary" className="h-11 px-5">
            {t(lang, "pages.contact.methods.directions.cta") as any}
          </ButtonLink>
        </div>
      </article>
    </div>
  </div>
</section>
