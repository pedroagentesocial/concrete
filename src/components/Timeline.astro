---
import SectionHeader from "./SectionHeader.astro";
import { aboutTimeline } from "../data/aboutTimeline";
import { t, type Lang } from "../i18n";

const { lang } = Astro.props as { lang: Lang };
const items = aboutTimeline.map((item) => ({
  id: item.id,
  title: t(lang, item.titleKey),
  description: t(lang, item.bodyKey)
}));
---

<section class="bg-white">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-16 sm:py-20">
    <SectionHeader title={t(lang, "pages.about.story.title")} subtitle={t(lang, "pages.about.story.subtitle")} align="center" />
    <div class="mx-auto max-w-3xl border-l border-muted pl-12">
      <div class="space-y-8">
        {items.map((item) => (
          <div class="relative">
            <span class="absolute -left-[54px] top-2 h-3 w-3 rounded-full bg-brand" aria-hidden="true" />
            <h3 class="text-lg font-semibold text-text">{item.title}</h3>
            <p class="mt-2 text-sm text-text/80">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
