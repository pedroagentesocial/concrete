---
import SectionHeader from "./SectionHeader.astro";
import { t, type Lang } from "../i18n";

const { lang } = Astro.props as { lang: Lang };
const items = t<string[]>(lang, "pages.contact.checklist.items");
---

<section class="bg-white">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-16 sm:py-20">
    <SectionHeader title={t(lang, "pages.contact.checklist.title")} subtitle={t(lang, "pages.contact.checklist.subtitle")} align="center" />
    <div class="mx-auto max-w-4xl rounded-2xl border border-muted bg-surface p-6 sm:p-8">
      <ul class="space-y-3 text-sm text-text/80">
        {items.map((item) => (
          <li class="flex items-start gap-3">
            <span class="mt-1 inline-flex h-5 w-5 items-center justify-center rounded-full border border-muted text-brand">
              <svg viewBox="0 0 16 16" aria-hidden="true" class="h-3 w-3 fill-current">
                <path d="M6.44 11.2 3.2 7.96l1.2-1.2 2.04 2.04 5.16-5.16 1.2 1.2-6.36 6.36Z" />
              </svg>
            </span>
            <span>{item}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>
