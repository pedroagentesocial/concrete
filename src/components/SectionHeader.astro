---
const { title, subtitle, align = "center" } = Astro.props as {
  title: string;
  subtitle?: string;
  align?: "center" | "left";
};
const wrapper =
  align === "left" ? "text-left" : "text-center max-w-3xl mx-auto";
---
<div class={`${wrapper} mb-10`}>
  <h2 class="text-3xl sm:text-4xl font-semibold tracking-tight text-text">
    {title}
  </h2>
  {subtitle ? (
    <p class="mt-3 text-base sm:text-lg text-text/80 leading-relaxed">
      {subtitle}
    </p>
  ) : null}
</div>
