---
import SectionHeader from "./SectionHeader.astro";
import Reveal from "./Reveal";
import { t, type Lang } from "../i18n";
import { whyUsItems, whyUsIcons } from "../data/whyUs";
const { lang } = Astro.props as { lang: Lang };
const trustItems = t(lang, "home.whyUs.trustStrip") as any[];
---
<section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16 sm:py-20">
  <Reveal client:load>
    <SectionHeader title={t(lang, "home.whyUs.title")} subtitle={t(lang, "home.whyUs.subtitle")} align="center" />
  </Reveal>
  <div class="mt-6 grid gap-3 sm:grid-cols-3">
    {trustItems.map((item, idx) => (
      <Reveal client:load delayMs={idx * 80}>
        <div class="rounded-2xl border border-muted bg-white px-4 py-3">
          <p class="text-xs uppercase tracking-[0.24em] text-muted">{item.title}</p>
          <p class="mt-1 text-sm font-semibold text-text">{item.value}</p>
        </div>
      </Reveal>
    ))}
  </div>
  <div class="mt-6 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
    {whyUsItems.map((item, idx) => (
      <Reveal client:load delayMs={idx * 80}>
        <article class="group rounded-2xl border border-muted bg-surface p-6 transition-all duration-200 ease-out hover:border-brand hover:-translate-y-0.5 hover:bg-white">
          <div class="h-1 w-10 rounded-full bg-brand"></div>
          <div
            class="mt-4 inline-flex h-12 w-12 items-center justify-center rounded-2xl border border-muted bg-white text-text/80 transition-transform duration-200 ease-out group-hover:scale-105 group-hover:rotate-1 motion-reduce:transform-none"
            set:html={whyUsIcons[item.icon]}
          />
          <h3 class="mt-4 text-xl font-semibold text-text">{t(lang, item.titleKey)}</h3>
          <p class="mt-3 text-text/80 leading-relaxed">{t(lang, item.descriptionKey)}</p>
          {item.metric ? (
            <div class="mt-4">
              <p class="text-2xl font-semibold text-brand">{t(lang, item.metric.valueKey)}</p>
              <p class="text-xs text-muted">{t(lang, item.metric.labelKey)}</p>
            </div>
          ) : null}
        </article>
      </Reveal>
    ))}
  </div>
</section>
