---
import SectionHeader from "./SectionHeader.astro";
import { serviceArea } from "../data/serviceArea";
import { t, type Lang } from "../i18n";

const { lang } = Astro.props as { lang: Lang };
const areas = serviceArea.areas.map((key) => t(lang, key));
---

<section class="bg-white">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-16 sm:py-20">
    <SectionHeader title={t(lang, "pages.contact.hours.title")} subtitle={t(lang, "pages.contact.hours.subtitle")} align="center" />
    <div class="grid gap-6 lg:gap-8 lg:grid-cols-2">
      <div class="rounded-2xl border border-muted bg-surface p-6 sm:p-8">
        <p class="text-xs uppercase tracking-[0.2em] text-muted">{t(lang, "pages.contact.hours.hoursLabel")}</p>
        <p class="mt-2 text-lg font-semibold text-text">{t(lang, "home.contact.hours")}</p>
        <p class="mt-2 text-sm text-text/80">{t(lang, "pages.contact.hours.note")}</p>
        <div class="mt-6 border-t border-muted pt-4">
          <p class="text-xs uppercase tracking-[0.2em] text-muted">{t(lang, "pages.contact.hours.hqLabel")}</p>
          <p class="mt-2 text-lg font-semibold text-text">{t(lang, serviceArea.hq.name)}</p>
          <p class="mt-1 text-sm text-text/80">{t(lang, serviceArea.hq.addressDisplay)}</p>
        </div>
      </div>
      <div class="rounded-2xl border border-muted bg-surface p-6 sm:p-8">
        <p class="text-xs uppercase tracking-[0.2em] text-muted">{t(lang, "pages.contact.hours.serviceAreaLabel")}</p>
        <ul class="mt-4 grid gap-2 text-sm text-text/80 sm:grid-cols-2">
          {areas.map((area) => (
            <li>{String(area)}</li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>
