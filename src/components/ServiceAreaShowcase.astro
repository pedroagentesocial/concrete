---
import SectionHeader from "./SectionHeader.astro";
import Reveal from "./Reveal";
import Button from "./Button";
import { serviceArea } from "../data/serviceArea";
import { t, type Lang } from "../i18n";
const { lang } = Astro.props as { lang: Lang };
const { hq, areas } = serviceArea;
---
<section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16 sm:py-20">
  <Reveal client:load>
    <SectionHeader title={t(lang, "home.serviceArea.title")} subtitle={t(lang, "home.serviceArea.subtitle")} align="center" />
  </Reveal>
  <div class="grid gap-6 lg:gap-8 lg:grid-cols-[1.1fr_0.9fr]">
    <Reveal client:load delayMs={80}>
      <div class="rounded-2xl overflow-hidden border border-muted bg-white">
        {hq.imageSrc ? (
          <picture>
            <source srcset={hq.imageSrc} type="image/utah.jpg" />
            <img src={hq.imageSrc} alt={hq.imageAltKey ? t(lang, hq.imageAltKey) : ""} loading="lazy" class="h-64 w-full object-cover" />
          </picture>
        ) : null}
      </div>
    </Reveal>
    <Reveal client:load delayMs={160}>
      <div class="rounded-2xl border border-muted bg-surface p-8">
        <p class="text-xs uppercase tracking-[0.24em] text-muted">{t(lang, "home.serviceArea.labels.mainYard")}</p>
        <h3 class="mt-2 text-2xl font-semibold text-text">{t(lang, hq.name)}</h3>
        <p class="mt-2 text-sm text-text/80">{t(lang, "home.serviceArea.hq.serviceArea")}</p>
        <div class="mt-4 grid gap-2 text-sm text-text/80">
          <p><span class="font-semibold text-text">{t(lang, "home.serviceArea.labels.address")}:</span> {t(lang, hq.addressDisplay)}</p>
          <p><span class="font-semibold text-text">{t(lang, "home.serviceArea.labels.call")}:</span> <a class="font-semibold" href={hq.phoneHref}>{t(lang, hq.phoneDisplay)}</a></p>
          <p><span class="font-semibold text-text">{t(lang, "home.serviceArea.labels.email")}:</span> <a class="font-semibold" href={hq.emailHref}>{t(lang, hq.emailDisplay)}</a></p>
          <p><span class="font-semibold text-text">{t(lang, "home.serviceArea.labels.hours")}:</span> {t(lang, hq.hoursKey)}</p>
        </div>
        <div class="mt-6 flex flex-col gap-3 sm:flex-row">
          <Button client:load onClick={() => (window.location.href = hq.phoneHref)} variant="primary" className="h-11 px-6">
            {t(lang, "home.serviceArea.ctaCall") as any}
          </Button>
          <Button client:load onClick={() => window.open(hq.mapHref, "_blank")} variant="secondary" className="h-11 px-6">
            {t(lang, "home.serviceArea.ctaDirections") as any}
          </Button>
        </div>
      </div>
    </Reveal>
  </div>
  <div class="mt-8 flex flex-wrap justify-center gap-2">
    {areas.map((area, idx) => (
      <Reveal client:load delayMs={idx * 60}>
        <span class="rounded-full border border-muted bg-white px-3 py-1.5 text-xs font-semibold text-text/80 transition-colors duration-200 hover:border-brand hover:text-brand">
          {t(lang, area)}
        </span>
      </Reveal>
    ))}
  </div>
</section>
