---
import { t, type Lang } from "../i18n";
import { contactInfo } from "../data/contactInfo";
import Button from "./Button";
import { LinkedInIcon, FacebookIcon, InstagramIcon, XIcon } from "./icons/SocialIcons";
const { lang } = Astro.props as { lang: Lang };
const info = contactInfo;
---

<section class="py-16 sm:py-20 bg-white">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="rounded-2xl border border-muted bg-surface p-10 sm:p-12">
      <div class="grid gap-10 lg:grid-cols-2">
        <div class="space-y-4">
          <h2 class="text-3xl sm:text-4xl font-semibold tracking-tight text-text leading-tight">
            {t(lang, "home.contactCta.headline")}
          </h2>
          <p class="max-w-xl text-base sm:text-lg leading-relaxed text-text/80">
            {t(lang, "home.contactCta.body")}
          </p>
          <p class="text-sm text-muted">{t(lang, "home.contactCta.trustLine")}</p>
          <div class="mt-6 flex flex-col sm:flex-row gap-3">
            <Button client:load onClick={() => (window.location.href = info.phoneHref)} variant="primary" className="h-12 px-6">
              {t(lang, "home.contactCta.primaryCta") as any}
            </Button>
            <Button client:load onClick={() => (window.location.href = `/${lang}/contact`)} variant="secondary" className="h-12 px-6">
              {t(lang, "home.contactCta.secondaryCta") as any}
            </Button>
          </div>
        </div>
        <div class="space-y-4">
          <div class="rounded-2xl border border-muted p-5 bg-white">
            <div class="space-y-3">
              <a href={info.phoneHref} class="flex items-center gap-3 rounded-xl border border-muted bg-white px-4 py-3 hover:border-brand hover:bg-surface focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2 focus-visible:ring-offset-bg">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5 text-text/70" aria-hidden="true">
                  <rect x="7" y="2" width="10" height="20" rx="2"></rect>
                  <path d="M11 18h2"></path>
                </svg>
                <div>
                  <p class="text-xs text-muted">{t(lang, "footer.labels.phone")}</p>
                  <p class="font-semibold text-text">{info.phoneDisplay}</p>
                </div>
              </a>
              <a href={info.emailHref} class="flex items-center gap-3 rounded-xl border border-muted bg-white px-4 py-3 hover:border-brand hover:bg-surface focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2 focus-visible:ring-offset-bg">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5 text-text/70" aria-hidden="true">
                  <rect x="3" y="5" width="18" height="14" rx="2"></rect>
                  <path d="M3 7l9 6 9-6"></path>
                </svg>
                <div>
                  <p class="text-xs text-muted">{t(lang, "footer.labels.email")}</p>
                  <p class="font-semibold text-text">{info.emailDisplay}</p>
                </div>
              </a>
              <a href={info.mapHref} target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 rounded-xl border border-muted bg-white px-4 py-3 hover:border-brand hover:bg-surface focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2 focus-visible:ring-offset-bg">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5 text-text/70" aria-hidden="true">
                  <path d="M12 21l-5-7a6 6 0 1 1 10 0l-5 7"></path>
                  <circle cx="12" cy="10" r="2.5"></circle>
                </svg>
                <div>
                  <p class="text-xs text-muted">{t(lang, "footer.labels.address")}</p>
                  <p class="font-semibold text-text">{info.addressDisplay}</p>
                </div>
              </a>
              <div class="pt-4 border-t border-muted">
                <p class="mb-2 text-xs text-muted">{t(lang, "footer.labels.followUs")}</p>
                <div class="flex items-center gap-2">
                  {info.social.map((s) => {
                    const label =
                      s.name === "LinkedIn"
                        ? t(lang, "common.a11y.visitLinkedIn")
                        : s.name === "Facebook"
                        ? t(lang, "common.a11y.visitFacebook")
                        : s.name === "Instagram"
                        ? t(lang, "common.a11y.visitInstagram")
                        : t(lang, "common.a11y.visitX");
                    const Icon =
                      s.name === "LinkedIn"
                        ? LinkedInIcon
                        : s.name === "Facebook"
                        ? FacebookIcon
                        : s.name === "Instagram"
                        ? InstagramIcon
                        : XIcon;
                    return (
                      <a
                        href={s.href}
                        target="_blank"
                        rel="noopener noreferrer"
                        aria-label={String(label)}
                        class="inline-flex h-11 w-11 items-center justify-center rounded-xl border border-muted bg-white text-text/80 transition-all duration-200 ease-out hover:bg-surface hover:border-brand hover:text-brand hover:-translate-y-0.5 active:translate-y-0 active:scale-[0.98] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2 focus-visible:ring-offset-bg"
                      >
                        <Icon className="h-5 w-5" />
                      </a>
                    );
                  })}
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
