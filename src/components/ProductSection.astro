---
import SectionHeader from "./SectionHeader.astro";
import Reveal from "./Reveal";
import Button from "./Button";
import DeliveryDetailsTrigger from "./DeliveryDetailsTrigger";
import { contactInfo } from "../data/contactInfo";
import type { ProductSection as ProductSectionType } from "../data/productSections";
import { t, type Lang } from "../i18n";

const { section, lang, reverse } = Astro.props as {
  section: ProductSectionType;
  lang: Lang;
  reverse?: boolean;
};

const imageWrap = reverse ? "lg:order-2" : "";
const contentWrap = reverse ? "lg:order-1" : "";
---
<section id={section.id} class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-16 sm:py-20 scroll-mt-24">
  <SectionHeader title={t(lang, section.titleKey)} subtitle={t(lang, section.subtitleKey)} align="center" />
  <div class="grid gap-8 lg:gap-10 lg:grid-cols-2">
    <Reveal client:load>
      <div class={`rounded-2xl overflow-hidden border border-muted bg-white ${imageWrap}`}>
        <picture>
          <source srcset={section.imageSrc} type="image/jpeg" />
          <img src={section.imageSrc} alt={t(lang, section.imageAltKey)} loading="lazy" class="h-full w-full object-cover" />
        </picture>
      </div>
    </Reveal>
    <Reveal client:load delayMs={120}>
      <div class={`rounded-2xl border border-muted bg-surface p-6 sm:p-8 ${contentWrap}`}>
        <p class="text-sm text-text/80">{t(lang, section.bodyKey)}</p>
        <ul class="mt-4 space-y-2 text-sm text-text/80">
          {section.highlightsKeys.map((key) => (
            <li class="flex items-start gap-2">
              <span class="mt-1 inline-flex h-4 w-4 items-center justify-center rounded-full border border-muted text-brand">
                <svg viewBox="0 0 16 16" aria-hidden="true" class="h-3 w-3 fill-current">
                  <path d="M6.44 11.2 3.2 7.96l1.2-1.2 2.04 2.04 5.16-5.16 1.2 1.2-6.36 6.36Z" />
                </svg>
              </span>
              <span>{t(lang, key)}</span>
            </li>
          ))}
        </ul>
        {section.specs ? (
          <div class="mt-5 rounded-2xl border border-muted bg-white p-4">
            <p class="text-sm font-semibold text-text">{t(lang, section.specs.titleKey)}</p>
            <ul class="mt-2 space-y-1 text-sm text-text/80">
              {section.specs.itemsKeys.map((key) => (
                <li>{t(lang, key)}</li>
              ))}
            </ul>
          </div>
        ) : null}
        <div class="mt-6">
          {section.id === "delivery" ? (
            <DeliveryDetailsTrigger client:load lang={lang} />
          ) : (
            <Button client:load onClick={() => (window.location.href = contactInfo.phoneHref)} variant="primary" className="h-11 px-6">
              {t(lang, section.ctaKey) as any}
            </Button>
          )}
        </div>
      </div>
    </Reveal>
  </div>
</section>
