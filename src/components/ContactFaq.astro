---
import SectionHeader from "./SectionHeader.astro";
import FaqAccordion from "./FaqAccordion";
import { t, type Lang } from "../i18n";

const { lang } = Astro.props as { lang: Lang };
---

<section class="bg-white">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-16 sm:py-20">
    <SectionHeader title={t(lang, "pages.contact.faq.title")} subtitle={t(lang, "pages.contact.faq.subtitle")} align="center" />
    <FaqAccordion client:load lang={lang} />
  </div>
</section>
