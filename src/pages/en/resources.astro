---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Reveal from "../../components/Reveal";
import SectionHeader from "../../components/SectionHeader.astro";
import { t } from "../../i18n";

const lang = "en";
const canonical = new URL(`/en/resources`, Astro.url).toString();
const alternateUrl = new URL(`/es/resources`, Astro.url).toString();
---

<BaseLayout
  title={t(lang, "pages.resources.title")}
  description={t(lang, "pages.resources.intro")}
  lang={lang}
  canonical={canonical}
  alternateLang="es"
  alternateUrl={alternateUrl}
>
  <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16 sm:py-20">
    <SectionHeader title={t(lang, "pages.resources.title")} subtitle={t(lang, "pages.resources.intro")} align="center" />
  </section>
</BaseLayout>
