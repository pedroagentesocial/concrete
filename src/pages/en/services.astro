---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Reveal from "../../components/Reveal";
import SectionHeader from "../../components/SectionHeader.astro";
import { t } from "../../i18n";
import { services } from "../../data/services";

const lang = "en";
const canonical = new URL(`/en/services`, Astro.url).toString();
const alternateUrl = new URL(`/es/services`, Astro.url).toString();
---

<BaseLayout
  title={t(lang, "pages.services.title")}
  description={t(lang, "pages.services.intro")}
  lang={lang}
  canonical={canonical}
  alternateLang="es"
  alternateUrl={alternateUrl}
>
  <section class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-16 sm:py-20">
    <SectionHeader title={t(lang, "pages.services.title")} subtitle={t(lang, "pages.services.intro")} align="center" />
  </section>
  <section class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-16 sm:py-20">
    <div class="space-y-12">
      {services.map((svc, idx) => {
        const bullets = svc.bulletsKey ? (t(lang, svc.bulletsKey) as any[]) : null;
        const imageSrcs = ["/images/services-1.jpg", "/images/services-2.jpg"];
        const imageSrc = imageSrcs[idx % imageSrcs.length];
        const altKey =
          svc.id === "delivery"
            ? "pages.servicesPage.images.deliveryAlt"
            : svc.id === "mixDesign"
            ? "pages.servicesPage.images.mixDesignAlt"
            : svc.id === "onSiteSupport"
            ? "pages.servicesPage.images.onSiteSupportAlt"
            : "pages.servicesPage.images.qualityAlt";
        const altText = String(t(lang, altKey));
        const imageFirst = idx % 2 === 0;
        return (
          <div class="grid gap-8 lg:grid-cols-2 items-stretch">
            <div class={`rounded-2xl overflow-hidden border border-muted ${imageFirst ? "" : "lg:order-2"}`}>
              <picture>
                <source srcset={imageSrc} type="image/jpeg" />
                <img
                  src={imageSrc}
                  alt={altText}
                  loading="lazy"
                  class="h-64 w-full object-cover sm:h-80 md:h-96"
                />
              </picture>
            </div>
            <article class={`bg-surface rounded-2xl border border-muted p-6 ${imageFirst ? "" : "lg:order-1"}`}>
              <h2 class="text-xl font-semibold text-text">{t(lang, svc.titleKey)}</h2>
              <p class="mt-3 text-text/80">{t(lang, svc.descriptionKey)}</p>
              {bullets && Array.isArray(bullets) && bullets.length > 0 ? (
                <ul class="mt-4 space-y-2 text-sm text-text/80">
                  {bullets.map((b) => <li>{b}</li>)}
                </ul>
              ) : null}
            </article>
          </div>
        );
      })}
    </div>
  </section>
</BaseLayout>
