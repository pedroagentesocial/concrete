---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SectionHeader from "../../components/SectionHeader.astro";
import Button from "../../components/Button";
import Reveal from "../../components/Reveal";
import AnchorNav from "../../components/AnchorNav.astro";
import ProductSection from "../../components/ProductSection.astro";
import ContactCtaSection from "../../components/ContactCtaSection.astro";
import DeliveryDetailsTrigger from "../../components/DeliveryDetailsTrigger";
import { contactInfo } from "../../data/contactInfo";
import { productSections } from "../../data/productSections";
import { t } from "../../i18n";

const lang = "en";
const canonical = new URL(`/en/products`, Astro.url).toString();
const alternateUrl = new URL(`/es/products`, Astro.url).toString();
const navItems = [
  { id: "cement", label: t(lang, "pages.products.nav.cement") },
  { id: "ready-mix", label: t(lang, "pages.products.nav.readyMix") },
  { id: "aggregates", label: t(lang, "pages.products.nav.aggregates") },
  { id: "delivery", label: t(lang, "pages.products.nav.delivery") }
];
---

<BaseLayout
  title={t(lang, "pages.products.title")}
  description={t(lang, "pages.products.intro")}
  lang={lang}
  canonical={canonical}
  alternateLang="es"
  alternateUrl={alternateUrl}
>
  <div class="bg-white">
    <section class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-16 sm:py-20">
      <Reveal client:load>
        <SectionHeader title={t(lang, "pages.products.hero.title")} subtitle={t(lang, "pages.products.hero.subtitle")} align="center" />
      </Reveal>
      <Reveal client:load delayMs={120}>
        <div class="mt-6 flex flex-col items-center gap-3 sm:flex-row sm:justify-center">
          <Button client:load onClick={() => (window.location.href = contactInfo.phoneHref)} variant="primary" className="h-11 px-6">
            {t(lang, "pages.products.hero.primaryCta") as any}
          </Button>
          <DeliveryDetailsTrigger client:load lang={lang} />
        </div>
      </Reveal>
    </section>

    <section class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <Reveal client:load delayMs={200}>
        <AnchorNav title={t(lang, "pages.products.navTitle")} items={navItems} />
      </Reveal>
    </section>

    {productSections.map((section, idx) => (
      <ProductSection section={section} lang={lang} reverse={idx % 2 === 1} />
    ))}

    <ContactCtaSection lang={lang} />
  </div>
</BaseLayout>
